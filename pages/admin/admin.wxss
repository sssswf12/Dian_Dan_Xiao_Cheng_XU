.auth-panel {
  margin-top: 80rpx;
  padding: 44rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(124, 96, 72, 0.1);
}

.auth-mascot {
  width: 132rpx;
  height: 132rpx;
  position: relative;
  margin-bottom: 24rpx;
}

.lock-top {
  width: 72rpx;
  height: 60rpx;
  position: absolute;
  left: 30rpx;
  top: 0;
  border: 8rpx solid #6d5650;
  border-bottom: 0;
  border-radius: 42rpx 42rpx 0 0;
}

.lock-body {
  width: 112rpx;
  height: 84rpx;
  position: absolute;
  left: 10rpx;
  bottom: 0;
  border: 5rpx solid #6d5650;
  border-radius: 16rpx;
  background: #ffe17b;
}

.lock-dot {
  width: 16rpx;
  height: 24rpx;
  position: absolute;
  left: 48rpx;
  top: 28rpx;
  border-radius: 10rpx;
  background: #403541;
}

.auth-title {
  color: #332b39;
  font-size: 40rpx;
  font-weight: 900;
}

.auth-text {
  margin-top: 12rpx;
  color: #81717d;
  font-size: 25rpx;
}

.auth-input {
  width: 100%;
  height: 82rpx;
  margin-top: 30rpx;
  padding: 0 22rpx;
  color: #332b39;
  font-size: 30rpx;
  border: 2rpx solid #efdccd;
  border-radius: 16rpx;
  background: #fffaf2;
}

.auth-button,
.auth-back {
  width: 100%;
  margin-top: 18rpx;
}

.admin-header {
  min-height: 168rpx;
  margin-bottom: 22rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ffd7de 0%, #fff0bd 50%, #cfeee9 100%);
  box-shadow: 0 14rpx 28rpx rgba(121, 92, 76, 0.1);
}

.admin-kicker {
  display: block;
  color: #6f6a77;
  font-size: 24rpx;
  font-weight: 700;
}

.admin-title {
  display: block;
  margin-top: 10rpx;
  color: #332b39;
  font-size: 42rpx;
  font-weight: 900;
}

.refresh-button {
  width: 124rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8d5a60;
  font-size: 24rpx;
  font-weight: 800;
  background: #ffffff;
  border: 2rpx solid #efddcc;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1.3fr;
  gap: 14rpx;
  margin: 22rpx 0;
}

.stat-item {
  min-height: 120rpx;
  padding: 18rpx 14rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: #fffaf1;
}

.stat-active {
  background: #edf9f6;
}

.stat-today {
  background: #fff1f1;
}

.stat-value {
  color: #332b39;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.stat-label {
  margin-top: 8rpx;
  color: #82727e;
  font-size: 23rpx;
}

.status-scroll {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.status-track {
  display: flex;
  gap: 12rpx;
}

.status-tab {
  height: 62rpx;
  min-width: 126rpx;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #6c5a68;
  font-size: 24rpx;
  font-weight: 800;
  border: 2rpx solid #eddccb;
  border-radius: 16rpx;
  background: #fffdf8;
}

.status-tab.active {
  color: #ffffff;
  border-color: #4aa783;
  background: #4aa783;
}

.admin-orders {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.admin-order-card {
  padding: 22rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(124, 96, 72, 0.08);
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-title-group {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.order-no {
  color: #332b39;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.25;
}

.order-time {
  margin-top: 8rpx;
  color: #8a7a84;
  font-size: 23rpx;
}

.order-meta-row {
  margin-top: 18rpx;
  padding: 16rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #635564;
  font-size: 25rpx;
  border-radius: 16rpx;
  background: #fff8ef;
}

.order-user {
  display: block;
  color: #332b39;
  font-size: 27rpx;
  font-weight: 850;
}

.order-location {
  display: block;
  margin-top: 6rpx;
  color: #746673;
  font-size: 23rpx;
}

.order-total {
  color: #ff6f70;
  font-weight: 900;
}

.order-dishes {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-dish {
  display: grid;
  grid-template-columns: 1fr 80rpx 80rpx;
  gap: 12rpx;
  align-items: center;
  color: #4a414c;
  font-size: 26rpx;
}

.dish-name {
  min-width: 0;
  line-height: 1.35;
}

.dish-qty {
  color: #8a7a84;
  text-align: center;
}

.dish-unit {
  color: #4a414c;
  text-align: right;
  font-weight: 700;
}

.order-remark {
  display: block;
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  color: #7f707a;
  font-size: 24rpx;
  line-height: 1.5;
  border-radius: 16rpx;
  background: #f7f0fa;
}

.admin-actions {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
}

.action-button {
  width: 156rpx;
}

.empty-action {
  width: 180rpx;
  margin: 26rpx auto 0;
}

.manage-form {
  padding: 22rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(124, 96, 72, 0.08);
}

.form-title {
  margin-top: 0;
  flex-wrap: wrap;
}

.clear-button {
  width: 112rpx;
  height: 52rpx;
  color: #9a6060;
  font-size: 24rpx;
  font-weight: 700;
  background: #fff0f0;
}

.form-row,
.textarea-row {
  min-height: 84rpx;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  border-top: 2rpx solid #f6eadf;
}

.textarea-row {
  align-items: flex-start;
}

.form-label {
  width: 104rpx;
  flex: 0 0 104rpx;
  color: #6d5e68;
  font-weight: 800;
}

.form-picker,
.form-input,
.form-textarea {
  flex: 1;
  min-height: 56rpx;
  color: #332b39;
  font-size: 28rpx;
}

.picker-value {
  height: 56rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 118rpx;
  padding: 10rpx 0;
  line-height: 1.45;
}

.save-button {
  width: 100%;
  margin-top: 18rpx;
}

.menu-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 22rpx;
}

.add-content-button {
  width: 210rpx;
  flex: 0 0 210rpx;
}

.menu-status-switch {
  height: 76rpx;
  padding: 8rpx;
  display: flex;
  gap: 8rpx;
  margin-bottom: 22rpx;
  border: 2rpx solid #ecdfd2;
  border-radius: 16rpx;
  background: #fffdf8;
}

.menu-status-tab {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6c5a68;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 12rpx;
}

.menu-status-tab.active {
  color: #ffffff;
  background: #4aa783;
}

.menu-empty-state {
  margin-top: 18rpx;
}

.menu-total {
  color: #8a7780;
  font-size: 24rpx;
  font-weight: 700;
}

.manage-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.manage-card {
  min-height: 132rpx;
  width: 100%;
  min-width: 0;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(124, 96, 72, 0.08);
  overflow: hidden;
}

.manage-card.is-disabled {
  opacity: 0.58;
}

.manage-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.manage-title {
  display: block;
  max-width: 100%;
  color: #332b39;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.25;
  white-space: normal;
  word-break: break-all;
}

.manage-meta,
.manage-desc {
  display: block;
  max-width: 100%;
  margin-top: 8rpx;
  color: #81717d;
  font-size: 23rpx;
  line-height: 1.45;
  white-space: normal;
  word-break: break-all;
}

.manage-actions {
  width: 132rpx;
  flex: 0 0 132rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.mini-action {
  width: 132rpx;
  height: 56rpx;
  font-size: 23rpx;
}

.menu-manage-card {
  align-items: stretch;
  flex-wrap: wrap;
}

.manage-thumb {
  width: 96rpx;
  height: 96rpx;
  flex: 0 0 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid rgba(82, 61, 50, 0.12);
  border-radius: 16rpx;
}

.manage-thumb-image {
  width: 100%;
  height: 100%;
  display: block;
}

.manage-thumb-dot {
  width: 48rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 28rpx;
}

.menu-manage-card .manage-main {
  flex: 1 1 0;
}

.menu-manage-card .manage-actions {
  width: 100%;
  flex: 1 0 100%;
  flex-direction: row;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.menu-manage-card .mini-action {
  flex: 1 1 0;
  min-width: 0;
}

.user-manage-card {
  align-items: flex-start;
  flex-wrap: wrap;
}

.user-manage-card .user-avatar {
  margin-top: 4rpx;
}

.user-manage-card .manage-main {
  flex: 1 1 0;
}

.user-manage-card .manage-actions {
  width: 100%;
  flex: 1 0 100%;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 14rpx;
}

.user-manage-card .mini-action {
  width: auto;
  min-width: 0;
  height: 64rpx;
  flex: 1 1 0;
  font-size: 24rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 72rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  border-radius: 16rpx;
  background: #4aa783;
}

.admin-profile {
  display: flex;
  flex-direction: column;
}

.profile-panel {
  padding: 28rpx;
  border: 2rpx solid #ece1d7;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 38rpx rgba(64, 53, 65, 0.08);
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 104rpx;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  border-radius: 26rpx;
  background: #4aa783;
}

.profile-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.profile-title {
  color: #82737c;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-name {
  margin-top: 8rpx;
  color: #2f2934;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.profile-list {
  margin-top: 30rpx;
  border-top: 2rpx solid #f0e8df;
}

.profile-row {
  min-height: 82rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 2rpx solid #f0e8df;
}

.profile-label {
  flex: 0 0 96rpx;
  color: #7f727a;
  font-size: 25rpx;
  font-weight: 800;
}

.profile-value {
  flex: 1;
  color: #332b39;
  font-size: 28rpx;
  font-weight: 750;
  line-height: 1.35;
  text-align: right;
}

.profile-action {
  width: 100%;
  margin-top: 22rpx;
}
