.edit-page {
  padding-bottom: calc(168rpx + env(safe-area-inset-bottom));
}

.edit-header {
  min-height: 150rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff0bd 0%, #ffd7de 52%, #cfeee9 100%);
  box-shadow: 0 14rpx 28rpx rgba(121, 92, 76, 0.1);
}

.edit-kicker {
  display: block;
  color: #6f6a77;
  font-size: 24rpx;
  font-weight: 700;
}

.edit-title {
  display: block;
  margin-top: 10rpx;
  color: #332b39;
  font-size: 42rpx;
  font-weight: 900;
}

.header-button {
  width: 124rpx;
  flex: 0 0 124rpx;
}

.preview-panel {
  margin-top: 22rpx;
  padding: 22rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(124, 96, 72, 0.08);
}

.preview-art {
  width: 180rpx;
  height: 180rpx;
  flex: 0 0 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid rgba(82, 61, 50, 0.12);
  border-radius: 18rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.plate {
  width: 116rpx;
  height: 88rpx;
  position: relative;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
}

.food-shape {
  position: absolute;
  border: 3rpx solid rgba(68, 53, 56, 0.16);
}

.food-main {
  width: 64rpx;
  height: 42rpx;
  left: 22rpx;
  top: 20rpx;
  border-radius: 42rpx 42rpx 28rpx 28rpx;
}

.food-small {
  width: 22rpx;
  height: 22rpx;
  right: 20rpx;
  top: 16rpx;
  border-radius: 50%;
  background: #fffaf0;
}

.food-dot {
  width: 16rpx;
  height: 16rpx;
  left: 26rpx;
  bottom: 16rpx;
  border-radius: 50%;
  background: #4aa783;
}

.art-noodle .food-main {
  width: 70rpx;
  height: 28rpx;
  top: 30rpx;
  border-radius: 16rpx;
}

.art-drink .plate {
  width: 68rpx;
  height: 104rpx;
  border-radius: 12rpx 12rpx 24rpx 24rpx;
}

.art-drink .food-main {
  width: 50rpx;
  height: 62rpx;
  left: 6rpx;
  top: 28rpx;
  border-radius: 8rpx 8rpx 18rpx 18rpx;
}

.art-dessert .food-main,
.art-snack .food-main {
  height: 46rpx;
  border-radius: 18rpx;
}

.image-actions {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.image-button {
  width: 100%;
}

.preset-title {
  margin-top: 24rpx;
}

.preset-total {
  color: #8a7780;
  font-size: 24rpx;
  font-weight: 700;
}

.preset-scroll {
  margin-top: 18rpx;
  height: 396rpx;
  padding: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
  border: 2rpx solid #f0dfce;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(124, 96, 72, 0.08);
}

.preset-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding-bottom: 12rpx;
}

.preset-item {
  min-width: 0;
  min-height: 122rpx;
  padding: 8rpx 6rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #6c5a68;
  font-size: 22rpx;
  font-weight: 800;
  border: 2rpx solid #eddccb;
  border-radius: 16rpx;
  background: #fffdf8;
}

.preset-item.active {
  color: #ffffff;
  border-color: #4aa783;
  background: #4aa783;
}

.preset-swatch {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 18rpx;
  background: #fff7e8;
}

.preset-image {
  width: 100%;
  height: 100%;
  display: block;
}

.edit-form {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #f0dfce;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(124, 96, 72, 0.08);
}

.form-row,
.textarea-row {
  min-height: 84rpx;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  border-top: 2rpx solid #f6eadf;
}

.form-row:first-child {
  border-top: 0;
}

.textarea-row {
  align-items: flex-start;
}

.form-label {
  width: 104rpx;
  flex: 0 0 104rpx;
  color: #6d5e68;
  font-weight: 800;
}

.form-picker,
.form-input,
.form-textarea {
  flex: 1;
  min-height: 56rpx;
  color: #332b39;
  font-size: 28rpx;
}

.picker-value {
  height: 56rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 118rpx;
  padding: 10rpx 0;
  line-height: 1.45;
}

.editor-actions {
  position: fixed;
  left: 50%;
  bottom: 0;
  z-index: 30;
  width: 100%;
  max-width: 480px;
  padding: 16rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  border-top: 2rpx solid #f0dfce;
  background: #fffef9;
  box-shadow: 0 -10rpx 24rpx rgba(84, 64, 54, 0.1);
  transform: translateX(-50%);
}

.action-cancel,
.action-save {
  flex: 1;
}
