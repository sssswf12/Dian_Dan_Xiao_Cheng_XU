<view class="page menu-page">
  <view class="hero">
    <view class="hero-copy">
      <text class="hero-kicker">{{currentUser ? currentUser.name : ''}}</text>
      <text class="hero-title">点单</text>
    </view>
    <view class="mascot">
      <view class="mascot-ear mascot-ear-left"></view>
      <view class="mascot-ear mascot-ear-right"></view>
      <view class="mascot-face">
        <view class="mascot-eye mascot-eye-left"></view>
        <view class="mascot-eye mascot-eye-right"></view>
        <view class="mascot-cheek mascot-cheek-left"></view>
        <view class="mascot-cheek mascot-cheek-right"></view>
        <view class="mascot-mouth"></view>
      </view>
      <view class="mascot-hat">
        <view class="hat-puff hat-puff-left"></view>
        <view class="hat-puff hat-puff-mid"></view>
        <view class="hat-puff hat-puff-right"></view>
        <view class="hat-band"></view>
      </view>
    </view>
  </view>

  <view class="search-box">
    <text class="search-icon">⌕</text>
    <input class="search-input" placeholder="搜索菜品、饮品、甜品或水果" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
  </view>

  <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-track">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-tab {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="section-title">
    <text>今日可选</text>
    <text class="menu-count">{{menuList.length}} 项</text>
  </view>

  <view wx:if="{{menuList.length}}" class="dish-list">
    <view wx:for="{{menuList}}" wx:key="id" class="dish-card">
      <view class="dish-art art-{{item.art}}" style="background: {{item.themeBg}};">
        <image wx:if="{{item.imageUrl}}" class="dish-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view wx:else class="plate">
          <view class="food-shape food-main" style="background: {{item.themeAccent}};"></view>
          <view class="food-shape food-small"></view>
          <view class="food-shape food-dot"></view>
        </view>
      </view>

      <view class="dish-info">
        <view class="dish-name-row">
          <text class="dish-name">{{item.name}}</text>
          <text wx:if="{{item.tag}}" class="small-pill">{{item.tag}}</text>
        </view>
        <text class="dish-desc">{{item.desc}}</text>
        <view class="dish-bottom">
          <text class="dish-category">{{item.categoryName}}</text>
          <text class="dish-unit">/{{item.unit}}</text>
        </view>
      </view>

      <view class="dish-action">
        <view wx:if="{{item.count}}" class="stepper">
          <button class="stepper-button" data-id="{{item.id}}" bindtap="decreaseItem">−</button>
          <text class="stepper-count">{{item.count}}</text>
          <button class="stepper-button" data-id="{{item.id}}" bindtap="increaseItem">+</button>
        </view>
        <button wx:else class="add-button" data-id="{{item.id}}" bindtap="addItem">+</button>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-face"></view>
    <text class="empty-title">没有找到内容</text>
    <text class="empty-text">换个关键词或分类再看看。</text>
  </view>

  <view wx:if="{{cart.totalCount > 0}}" class="cart-dock">
    <view class="cart-summary">
      <text class="cart-title">{{cart.totalCount}} 件已选</text>
      <text class="cart-tip">确认后会提交订单</text>
    </view>
    <button class="cart-submit" bindtap="goCart">去确认</button>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav-item active">点单</view>
    <view class="bottom-nav-item" bindtap="goCart">确认</view>
    <view class="bottom-nav-item" bindtap="goOrders">订单</view>
    <view class="bottom-nav-item" bindtap="goProfile">我</view>
  </view>
</view>
