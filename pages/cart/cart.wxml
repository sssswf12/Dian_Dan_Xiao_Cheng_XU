<view class="page page-without-dock cart-page">
  <view class="cart-header">
    <view>
      <text class="cart-kicker">{{shop.name}}</text>
      <text class="cart-title">确认下单</text>
      <text class="cart-note">当前成员：{{currentUser ? currentUser.name : '未登录'}}</text>
    </view>
    <view class="cart-basket">
      <view class="basket-handle"></view>
      <view class="basket-face">
        <view class="basket-eye basket-eye-left"></view>
        <view class="basket-eye basket-eye-right"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{cart.items.length}}">
    <view class="section-title">
      <text>已选内容</text>
      <button class="clear-button" bindtap="clearCart">清空</button>
    </view>

    <view class="cart-list">
      <view wx:for="{{cart.items}}" wx:key="id" class="cart-item">
        <view class="cart-art art-{{item.art}}" style="background: {{item.themeBg}};">
          <image wx:if="{{item.imageUrl}}" class="cart-image" src="{{item.imageUrl}}" mode="aspectFill" />
          <view wx:else class="cart-art-dot" style="background: {{item.themeAccent}};"></view>
        </view>
        <view class="cart-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-meta">{{item.categoryName}} / {{item.unit}}</text>
        </view>
        <view class="stepper">
          <button class="stepper-button" data-id="{{item.id}}" bindtap="decreaseItem">−</button>
          <text class="stepper-count">{{item.quantity}}</text>
          <button class="stepper-button" data-index="{{index}}" bindtap="increaseItem">+</button>
        </view>
      </view>
    </view>

    <view class="order-form">
      <view class="section-title form-title">
        <text>下单信息</text>
      </view>

      <view class="form-row">
        <text class="form-label">成员</text>
        <view class="form-static" bindtap="goProfile">{{currentUser ? currentUser.name : '点击登录'}}</view>
      </view>

      <view class="form-row">
        <text class="form-label">方式</text>
        <picker class="form-picker" mode="selector" range="{{diningTypes}}" value="{{diningTypeIndex}}" bindchange="onDiningTypeChange">
          <view class="picker-value">{{diningTypes[diningTypeIndex]}}</view>
        </picker>
      </view>

      <view class="form-row">
        <text class="form-label">位置</text>
        <input class="form-input" placeholder="例如 客厅 / 房间 / 不填也可以" value="{{location}}" bindinput="onLocationInput" maxlength="24" />
      </view>

      <view class="textarea-row">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" placeholder="口味、温度、切法或其他需求" value="{{remark}}" bindinput="onRemarkInput" maxlength="120" auto-height />
      </view>
    </view>

    <view class="checkout-panel">
      <view>
        <text class="checkout-label">共 {{cart.totalCount}} 件</text>
        <text class="checkout-tip">确认后会提交订单</text>
      </view>
      <button class="primary-button submit-button" loading="{{submitting}}" bindtap="submitOrder">确认下单</button>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-face"></view>
    <text class="empty-title">还没有选择内容</text>
    <text class="empty-text">先去点单页选几样需要的。</text>
    <button class="primary-button empty-action" bindtap="goMenu">去点单</button>
  </view>

  <view class="bottom-nav">
    <view class="bottom-nav-item" bindtap="goMenu">点单</view>
    <view class="bottom-nav-item active">确认</view>
    <view class="bottom-nav-item" bindtap="goOrders">订单</view>
    <view class="bottom-nav-item" bindtap="goProfile">我</view>
  </view>
</view>
