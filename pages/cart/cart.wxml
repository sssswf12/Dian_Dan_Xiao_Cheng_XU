<view class="page page-without-dock cart-page">
  <view class="cart-header">
    <view>
      <text class="cart-kicker">{{shop.name}}</text>
      <text class="cart-title">确认订单</text>
    </view>
    <view class="cart-basket">
      <view class="basket-handle"></view>
      <view class="basket-face">
        <view class="basket-eye basket-eye-left"></view>
        <view class="basket-eye basket-eye-right"></view>
      </view>
    </view>
  </view>

  <view class="nav-strip">
    <button class="nav-button" bindtap="goMenu">点单</button>
    <button class="nav-button active">购物车</button>
    <button class="nav-button" bindtap="goOrders">订单</button>
  </view>

  <view wx:if="{{cart.items.length}}">
    <view class="section-title">
      <text>已选菜品</text>
      <button class="clear-button" bindtap="clearCart">清空</button>
    </view>

    <view class="cart-list">
      <view wx:for="{{cart.items}}" wx:key="id" class="cart-item">
        <view class="cart-art art-{{item.art}}" style="background: {{item.themeBg}};">
          <view class="cart-art-dot" style="background: {{item.themeAccent}};"></view>
        </view>
        <view class="cart-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-meta">¥{{item.priceText}} / {{item.unit}}</text>
        </view>
        <view class="stepper">
          <button class="stepper-button" data-id="{{item.id}}" bindtap="decreaseItem">−</button>
          <text class="stepper-count">{{item.quantity}}</text>
          <button class="stepper-button" data-id="{{item.id}}" bindtap="increaseItem">+</button>
        </view>
      </view>
    </view>

    <view class="order-form">
      <view class="section-title form-title">
        <text>用餐信息</text>
      </view>

      <view class="form-row">
        <text class="form-label">方式</text>
        <picker class="form-picker" mode="selector" range="{{diningTypes}}" value="{{diningTypeIndex}}" bindchange="onDiningTypeChange">
          <view class="picker-value">{{diningTypes[diningTypeIndex]}}</view>
        </picker>
      </view>

      <view class="form-row">
        <text class="form-label">桌号</text>
        <input class="form-input" placeholder="例如 3 号桌 / 小会议室" value="{{tableNo}}" bindinput="onTableInput" maxlength="24" />
      </view>

      <view class="textarea-row">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" placeholder="口味、忌口、打包等需求" value="{{remark}}" bindinput="onRemarkInput" maxlength="120" auto-height />
      </view>
    </view>

    <view class="checkout-panel">
      <view>
        <text class="checkout-label">合计 {{cart.totalCount}} 件</text>
        <text class="checkout-price">¥{{cart.totalPriceText}}</text>
      </view>
      <button class="primary-button submit-button" loading="{{submitting}}" bindtap="submitOrder">提交订单</button>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-face"></view>
    <text class="empty-title">购物车是空的</text>
    <text class="empty-text">先去菜单里选几样想吃的。</text>
    <button class="primary-button empty-action" bindtap="goMenu">去点单</button>
  </view>
</view>
